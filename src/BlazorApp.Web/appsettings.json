{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=blazorapp;Username=postgres;Password=postgres123"

  },
  "AppSettings": {
    "AppName": "System Zarządzania",
    "CompanyName": "Nazwa Firmy Sp. z o.o.",
    "LogoPath": "wwwroot/images/logo.png",
    "DefaultCulture": "pl-PL",
    "TimeZone": "Central European Standard Time"
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "noreply@firma.pl",
    "Password": "PLACEHOLDER",
    "FromName": "System Zarządzania",
    "FromAddress": "noreply@firma.pl"
  },
  "Sms": {
    "Provider": "Twilio",
    "AccountSid": "PLACEHOLDER",
    "AuthToken": "PLACEHOLDER",
    "FromNumber": "+48XXXXXXXXX"
  },
  "Archive": {
    "DefaultStoragePath": "/app/archiwum",
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".tiff", ".xlsx", ".docx" ],
    "MaxFileSizeMb": 50
  },
  "Scheduler": {
    "DeadlineReminderHours": 24,
    "EscalationAfterDays": 3,
    "DailyDigestTime": "07:00"
  },
  "Security": {
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30,
    "PasswordMinLength": 8,
    "RequireSpecialCharacter": true,
    "SessionTimeoutMinutes": 480
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
