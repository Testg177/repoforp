@page "/reports"
@attribute [Authorize(Policy = "CanViewReports")]
@inject IReportsService ReportsService

<PageTitle>Raporty</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Raporty</MudText>
<MudGrid>
    @foreach (var tile in _tiles)
    {
        <MudItem xs="12" sm="6" md="3">
            <div class="kpi-card @tile.Accent card">
                <div class="kpi-label">@tile.Title</div>
                <div class="kpi-value">@tile.Value</div>
                <div class="text-muted">@tile.Description</div>
            </div>
        </MudItem>
    }
</MudGrid>

<MudPaper Class="pa-4 card mt-4">
    <MudText Typo="Typo.h4" Class="mb-2">Eksporty</MudText>
    <MudText Class="text-muted">QuestPDF i ClosedXML sa podlaczone w warstwie infrastruktury; tutaj mozemy dodac finalne akcje eksportu dla raportow biznesowych.</MudText>
</MudPaper>

@code {
    private IReadOnlyList<ReportTileDto> _tiles = [];

    protected override async Task OnInitializedAsync()
    {
        _tiles = await ReportsService.GetTilesAsync();
    }
}
