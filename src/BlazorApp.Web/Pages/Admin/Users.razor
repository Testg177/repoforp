@page "/admin/users"
@attribute [Authorize(Policy = "CanManageUsers")]
@inject IUserDirectoryService UserDirectoryService

<PageTitle>Uzytkownicy</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Uzytkownicy</MudText>
<MudPaper Class="pa-4 card">
    <div class="data-table-header">Uzytkownik / Dzial / Role</div>
    @foreach (var user in _users)
    {
        <div class="data-table-row">
            <div class="table-row-main">
                <div>
                    <div>@user.FullName</div>
                    <div class="text-muted">@user.Email</div>
                </div>
                <div class="text-right">
                    <div>@user.Department</div>
                    <div class="text-muted mono">@string.Join(", ", user.Roles)</div>
                </div>
            </div>
        </div>
    }
</MudPaper>

@code {
    private IReadOnlyList<UserListItemDto> _users = [];

    protected override async Task OnInitializedAsync()
    {
        _users = await UserDirectoryService.GetUsersAsync();
    }
}
