@page "/approvals"
@using BlazorApp.Domain.Entities
@using BlazorApp.Domain.Enums
@using BlazorApp.Infrastructure.Data
@using MudBlazor
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Policy = "CanApproveForms")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthState

<PageTitle>Do zatwierdzenia</PageTitle>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <div style="font-size:18px;font-weight:700;color:#e6edf3;">Do zatwierdzenia</div>
        <div style="font-size:12px;color:#7d8590;margin-top:2px;">@_pending.Count oczekujących</div>
    </div>
</div>

<div class="dash-panel">
    @if (_loading)
    {
        <div style="padding:40px;text-align:center;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
        </div>
    }
    else if (_pending.Count == 0)
    {
        <div style="padding:48px;text-align:center;color:#484f58;">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Style="font-size:3rem;opacity:.3;" />
            <div style="margin-top:12px;font-size:14px;">Brak formularzy do zatwierdzenia</div>
        </div>
    }
    else
    {
        @foreach (var s in _pending)
        {
            <div class="fa-row status-@s.Status.ToString().ToLower()">
                <div class="fa-info">
                    <div class="fa-title">@s.FormDefinition?.Title</div>
                    <div class="fa-meta">
                        @s.SubmittedBy?.FullName · złożono @s.SubmittedAt.ToString("dd.MM.yyyy HH:mm")
                    </div>
                </div>
                <div class="fa-right" style="align-items:center;flex-direction:row;gap:8px;">
                    <span class="fa-date @(s.IsLate ? "overdue" : "")">
                        Termin: @s.DueDate.ToString("dd.MM.yyyy")
                    </span>
                    <span class="sz-badge-pill badge-@s.Status.ToString().ToLower()">
                        @GetStatusLabel(s.Status)
                    </span>
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                   Href="@($"/forms/{s.Id}")" />
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               OnClick="@(() => ApproveAsync(s))">Zatwierdź</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => RejectAsync(s))">Odrzuć</MudButton>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<FormSubmission> _pending = [];
    private bool _loading = true;
    private string? _reviewerId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _reviewerId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _pending = await db.FormSubmissions
            .Include(s => s.FormDefinition)
            .Include(s => s.SubmittedBy)
            .Where(s => s.Status == SubmissionStatus.Submitted || s.Status == SubmissionStatus.InReview)
            .OrderBy(s => s.DueDate)
            .ToListAsync();
        _loading = false;
    }

    private async Task ApproveAsync(FormSubmission s)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.FormSubmissions.FindAsync(s.Id);
        if (item is null) return;
        item.Status = SubmissionStatus.Approved;
        item.ReviewedByUserId = _reviewerId;
        item.ReviewedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
        Snackbar.Add("Formularz zatwierdzony", Severity.Success);
        _pending.Remove(s);
    }

    private async Task RejectAsync(FormSubmission s)
    {
        var parameters = new DialogParameters<RejectDialog> { { x => x.SubmissionId, s.Id } };
        var dialog = await DialogService.ShowAsync<RejectDialog>("Odrzuć formularz", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }

    private static string GetStatusLabel(SubmissionStatus st) => st switch
    {
        SubmissionStatus.Submitted => "Złożony",
        SubmissionStatus.InReview  => "W przeglądzie",
        _ => st.ToString()
    };
}
