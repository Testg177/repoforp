@page "/admin/forms"
@using BlazorApp.Domain.Entities
@using BlazorApp.Infrastructure.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@attribute [Authorize(Policy = "CanManageUsers")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Definicje formularzy</PageTitle>

<AdminTabs />

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div style="font-size:18px;font-weight:700;color:#e6edf3;">Definicje formularzy</div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/admin/forms/builder/new">
        Nowy formularz (kreator)
    </MudButton>
</div>

<div class="dash-panel">
    @if (_loading)
    {
        <div style="padding:40px;text-align:center;"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" /></div>
    }
    else if (_forms.Count == 0)
    {
        <div style="padding:40px;text-align:center;color:#484f58;font-size:13px;">Brak zdefiniowanych formularzy</div>
    }
    else
    {
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr style="border-bottom:1px solid rgba(240,246,252,0.08);">
                    @foreach (var h in new[]{"Kod","Tytuł","Kategoria","Role","Wymaga zatwierdzenia","Status","Akcje"})
                    {
                        <th style="padding:10px 18px;text-align:left;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;">@h</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var f in _forms)
                {
                    <tr style="border-bottom:1px solid rgba(240,246,252,0.04);">
                        <td style="padding:10px 18px;font-size:12px;color:#58a6ff;font-family:monospace;">@f.Code</td>
                        <td style="padding:10px 18px;font-size:13px;color:#e6edf3;font-weight:500;">@f.Title</td>
                        <td style="padding:10px 18px;font-size:12px;color:#7d8590;">@f.Category</td>
                        <td style="padding:10px 18px;font-size:11px;color:#7d8590;">@string.Join(", ", f.AssignedRoles)</td>
                        <td style="padding:10px 18px;">
                            @if (f.RequiresApproval)
                            { <span class="sz-badge-pill badge-inreview">Tak</span> }
                            else
                            { <span class="sz-badge-pill badge-draft">Nie</span> }
                        </td>
                        <td style="padding:10px 18px;">
                            @if (f.IsActive)
                            { <span class="sz-badge-pill badge-approved">Aktywny</span> }
                            else
                            { <span class="sz-badge-pill badge-rejected">Nieaktywny</span> }
                        </td>
                        <td style="padding:10px 18px;">
                            <MudIconButton Icon="@Icons.Material.Filled.Build" Size="Size.Small"
                                           Href="@($"/admin/forms/builder/{f.Id}")" Title="Kreator" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEdit(f))" Title="Szybka edycja" />
                            <MudIconButton Icon="@(f.IsActive ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                           Size="Size.Small" Color="@(f.IsActive ? Color.Warning : Color.Success)"
                                           OnClick="@(() => ToggleActive(f))" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<style>
    .fd-input { width:100%;padding:9px 11px;background:rgba(240,246,252,0.04);border:1px solid rgba(240,246,252,0.12);border-radius:7px;color:#e6edf3;font-size:13px;outline:none;box-sizing:border-box; }
    .fd-input:focus { border-color:rgba(88,166,255,0.5); }
    .fd-label { display:block;font-size:11px;font-weight:500;color:#7d8590;margin-bottom:5px; }
</style>

@if (_editForm is not null)
{
    <div style="position:fixed;inset:0;z-index:999;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;"
         @onclick="CancelEdit">
        <div style="width:520px;background:#161b22;border:1px solid rgba(240,246,252,0.12);border-radius:12px;padding:28px;position:relative;"
             @onclick:stopPropagation="true">
            <div style="font-size:16px;font-weight:700;color:#e6edf3;margin-bottom:20px;">
                @(_editForm.Id == 0 ? "Nowy formularz (szybka edycja)" : "Edytuj formularz")
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                <div>
                    <label class="fd-label">Kod *</label>
                    <input @bind="_editForm.Code" class="fd-input" placeholder="np. RAPORT_DZIENNY" />
                </div>
                <div>
                    <label class="fd-label">Tytuł *</label>
                    <input @bind="_editForm.Title" class="fd-input" placeholder="Nazwa formularza" />
                </div>
            </div>
            <div style="margin-bottom:12px;">
                <label class="fd-label">Opis</label>
                <textarea @bind="_editForm.Description" class="fd-input" rows="2" style="resize:none;"></textarea>
            </div>
            <div style="margin-bottom:16px;">
                <label class="fd-label">Kategoria</label>
                <input @bind="_editForm.Category" class="fd-input" placeholder="np. BHP, HR" />
            </div>
            <div style="display:flex;gap:20px;margin-bottom:20px;">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:#e6edf3;">
                    <input type="checkbox" @bind="_editForm.IsActive" style="accent-color:#58a6ff;width:14px;height:14px;" />
                    Aktywny
                </label>
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:#e6edf3;">
                    <input type="checkbox" @bind="_editForm.RequiresApproval" style="accent-color:#58a6ff;width:14px;height:14px;" />
                    Wymaga zatwierdzenia
                </label>
            </div>
            <div style="display:flex;gap:10px;justify-content:flex-end;">
                <button @onclick="CancelEdit"
                        style="padding:8px 18px;border-radius:7px;border:1px solid rgba(240,246,252,0.15);background:transparent;color:#e6edf3;font-size:13px;cursor:pointer;">
                    Anuluj
                </button>
                <button @onclick="SaveForm"
                        style="padding:8px 20px;border-radius:7px;border:none;background:#58a6ff;color:#0d1117;font-size:13px;font-weight:600;cursor:pointer;">
                    Zapisz
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<FormDefinition> _forms = [];
    private bool _loading = true;
    private FormDefinition? _editForm;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _forms = await db.FormDefinitions.OrderBy(f => f.Title).ToListAsync();
        _loading = false;
    }

    private void OpenNew()  => _editForm = new FormDefinition { IsActive = true, RequiresApproval = true };
    private void OpenEdit(FormDefinition f) => _editForm = new FormDefinition
    {
        Id = f.Id, Code = f.Code, Title = f.Title, Description = f.Description,
        Category = f.Category, IsActive = f.IsActive, RequiresApproval = f.RequiresApproval,
        AssignedRoles = f.AssignedRoles, AssignedDepartments = f.AssignedDepartments
    };
    private void CancelEdit() => _editForm = null;

    private async Task SaveForm()
    {
        if (_editForm is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_editForm.Id == 0)
            db.FormDefinitions.Add(_editForm);
        else
            db.FormDefinitions.Update(_editForm);
        await db.SaveChangesAsync();
        _editForm = null;
        await LoadData();
        Snackbar.Add("Zapisano", Severity.Success);
    }

    private async Task ToggleActive(FormDefinition f)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.FormDefinitions.FindAsync(f.Id);
        if (item is null) return;
        item.IsActive = !item.IsActive;
        await db.SaveChangesAsync();
        f.IsActive = item.IsActive;
    }
}
