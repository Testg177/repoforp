@page "/admin/forms/builder/new"
@page "/admin/forms/builder/{FormId:int}"
@using BlazorApp.Domain.Entities
@using BlazorApp.Domain.Enums
@using DomainFieldType = BlazorApp.Domain.Enums.FieldType
@using BlazorApp.Infrastructure.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json
@attribute [Authorize(Policy = "CanManageUsers")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(IsNew ? "Nowy formularz" : $"Kreator: {_title}")</PageTitle>

<style>
    .fb-input { width:100%;padding:9px 11px;background:rgba(240,246,252,0.04);border:1px solid rgba(240,246,252,0.12);border-radius:7px;color:#e6edf3;font-size:13px;outline:none;transition:border-color .15s;box-sizing:border-box; }
    .fb-input:focus { border-color:rgba(88,166,255,0.5);background:rgba(240,246,252,0.06); }
    .fb-input::placeholder { color:#484f58; }
    .fb-label { display:block;font-size:11px;font-weight:500;color:#7d8590;margin-bottom:5px; }
    .fb-select { width:100%;padding:9px 11px;background:#1c2128;border:1px solid rgba(240,246,252,0.12);border-radius:7px;color:#e6edf3;font-size:13px;outline:none;box-sizing:border-box; }
    .field-row { display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid rgba(240,246,252,0.05);transition:background .12s; }
    .field-row:hover { background:rgba(240,246,252,0.03); }
    .field-row.editing { background:rgba(88,166,255,0.06);border-left:3px solid #58a6ff; }
    .field-type-badge { padding:2px 8px;border-radius:12px;font-size:10px;font-weight:600;background:rgba(88,166,255,0.12);color:#58a6ff;white-space:nowrap; }
    .btn-icon { width:28px;height:28px;border-radius:6px;border:1px solid rgba(240,246,252,0.1);background:transparent;color:#7d8590;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .15s;flex-shrink:0; }
    .btn-icon:hover { background:rgba(240,246,252,0.08);color:#e6edf3; }
    .btn-icon.danger:hover { background:rgba(248,81,73,0.12);color:#f85149;border-color:rgba(248,81,73,0.3); }
    .editor-panel { background:rgba(88,166,255,0.04);border:1px solid rgba(88,166,255,0.15);border-radius:10px;padding:18px;margin:8px 0; }
    .opt-tag { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;background:rgba(240,246,252,0.06);border:1px solid rgba(240,246,252,0.1);border-radius:20px;font-size:12px;color:#e6edf3;margin:3px; }
</style>

<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                   OnClick="@(() => Nav.NavigateTo("/admin/forms"))" />
    <div style="flex:1;">
        <div style="font-size:18px;font-weight:700;color:#e6edf3;">
            @(IsNew ? "Nowy formularz" : $"Kreator: {_title}")
        </div>
        <div style="font-size:12px;color:#7d8590;margin-top:2px;">@_fields.Count pól · ostatni zapis: @_lastSaved</div>
    </div>
    <button @onclick="Preview" style="padding:8px 16px;border-radius:7px;border:1px solid rgba(240,246,252,0.15);background:transparent;color:#e6edf3;font-size:13px;cursor:pointer;">
        <span style="margin-right:5px;">👁</span> Podgląd
    </button>
    <button @onclick="SaveAll" disabled="@_saving"
            style="padding:8px 20px;border-radius:7px;border:none;background:#58a6ff;color:#0d1117;font-size:13px;font-weight:600;cursor:pointer;opacity:@(_saving?"0.6":"1");">
        @(_saving ? "Zapisywanie..." : "💾 Zapisz formularz")
    </button>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div style="display:grid;grid-template-columns:300px 1fr;gap:16px;align-items:start;">

        <!-- ── LEFT: Metadata ─────────────────────────────── -->
        <div>
            <div class="dash-panel" style="padding:18px;margin-bottom:12px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:14px;">Ustawienia formularza</div>

                <div style="margin-bottom:10px;">
                    <label class="fb-label">Kod *</label>
                    <input @bind="_code" class="fb-input" placeholder="np. RAPORT_DZIENNY" style="font-family:monospace;font-size:12px;" />
                </div>
                <div style="margin-bottom:10px;">
                    <label class="fb-label">Tytuł *</label>
                    <input @bind="_title" class="fb-input" placeholder="Nazwa formularza" />
                </div>
                <div style="margin-bottom:10px;">
                    <label class="fb-label">Opis</label>
                    <textarea @bind="_description" class="fb-input" placeholder="Opis i cel formularza" rows="3" style="resize:vertical;"></textarea>
                </div>
                <div style="margin-bottom:10px;">
                    <label class="fb-label">Kategoria</label>
                    <input @bind="_category" class="fb-input" placeholder="np. BHP, HR, Produkcja" />
                </div>
                <div style="margin-bottom:10px;">
                    <label class="fb-label">Termin realizacji (dni)</label>
                    <input @bind="_escalationDays" type="number" min="1" class="fb-input" />
                </div>

                <div style="display:flex;flex-direction:column;gap:10px;margin-top:14px;">
                    @foreach (var (lbl, val, set) in new (string, bool, Action<bool>)[]
                    {
                        ("Formularz aktywny",      _isActive,       v => _isActive       = v),
                        ("Wymaga zatwierdzenia",   _reqApproval,    v => _reqApproval     = v),
                    })
                    {
                        var l2 = lbl; var v2 = val; var s2 = set;
                        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                            <div style="position:relative;width:34px;height:18px;flex-shrink:0;" @onclick="@(() => { s2(!v2); StateHasChanged(); })">
                                <div style="position:absolute;inset:0;border-radius:18px;background:@(v2 ? "#58a6ff" : "rgba(240,246,252,0.1)");transition:.2s;cursor:pointer;">
                                    <div style="position:absolute;height:14px;width:14px;left:@(v2 ? "18px" : "2px");top:2px;border-radius:50%;background:white;transition:.2s;"></div>
                                </div>
                            </div>
                            <span style="font-size:13px;color:#e6edf3;">@l2</span>
                        </label>
                    }
                </div>
            </div>

            <div class="dash-panel" style="padding:18px;margin-bottom:12px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:12px;">Przypisane role</div>
                @foreach (var role in _availableRoles)
                {
                    var r = role;
                    <label style="display:flex;align-items:center;gap:8px;padding:6px 0;cursor:pointer;border-bottom:1px solid rgba(240,246,252,0.04);">
                        <input type="checkbox" checked="@_assignedRoles.Contains(r)"
                               @onchange="@(e => ToggleRole(r, (bool)(e.Value??false)))"
                               style="width:14px;height:14px;accent-color:#58a6ff;cursor:pointer;" />
                        <span style="font-size:13px;color:#e6edf3;">@r</span>
                    </label>
                }
            </div>

            <div class="dash-panel" style="padding:18px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:10px;">Działy</div>
                <label class="fb-label">Oddzielone przecinkami</label>
                <input @bind="_departments" class="fb-input" placeholder="IT, HR, Produkcja" />
            </div>
        </div>

        <!-- ── RIGHT: Field builder ───────────────────────── -->
        <div>
            <div class="dash-panel">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid rgba(240,246,252,0.06);">
                    <span style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;">Pola formularza (@_fields.Count)</span>
                    <button @onclick="AddField"
                            style="display:flex;align-items:center;gap:6px;padding:6px 14px;border-radius:7px;border:1px solid rgba(88,166,255,0.3);background:rgba(88,166,255,0.08);color:#58a6ff;font-size:12px;font-weight:600;cursor:pointer;">
                        + Dodaj pole
                    </button>
                </div>

                @if (_fields.Count == 0)
                {
                    <div style="padding:48px;text-align:center;color:#484f58;">
                        <div style="font-size:2rem;margin-bottom:8px;">📋</div>
                        <div style="font-size:13px;">Brak pól. Kliknij "Dodaj pole" aby zacząć.</div>
                    </div>
                }
                else
                {
                    @for (int i = 0; i < _fields.Count; i++)
                    {
                        var idx = i;
                        var f = _fields[i];
                        <div class="field-row @(_editingIndex == idx ? "editing" : "")">
                            <span style="width:22px;height:22px;border-radius:4px;background:rgba(240,246,252,0.06);display:flex;align-items:center;justify-content:center;font-size:11px;color:#484f58;flex-shrink:0;">@(idx+1)</span>
                            <span style="font-size:14px;flex-shrink:0;">@GetFieldIcon(f.Type)</span>
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;color:#e6edf3;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @(string.IsNullOrEmpty(f.Label) ? "(bez etykiety)" : f.Label)
                                </div>
                                <div style="font-size:11px;color:#484f58;margin-top:1px;">@f.FieldKey</div>
                            </div>
                            <span class="field-type-badge">@f.Type</span>
                            @if (f.IsRequired)
                            {
                                <span style="font-size:10px;color:#f85149;font-weight:600;">*</span>
                            }
                            <button class="btn-icon" @onclick="@(() => MoveUp(idx))" title="Wyżej" disabled="@(idx==0)">↑</button>
                            <button class="btn-icon" @onclick="@(() => MoveDown(idx))" title="Niżej" disabled="@(idx==_fields.Count-1)">↓</button>
                            <button class="btn-icon" @onclick="@(() => ToggleEdit(idx))" title="Edytuj"
                                    style="color:@(_editingIndex==idx ? "#58a6ff" : "#7d8590");">✏</button>
                            <button class="btn-icon danger" @onclick="@(() => RemoveField(idx))" title="Usuń">🗑</button>
                        </div>

                        @if (_editingIndex == idx)
                        {
                            <div style="padding:0 14px 14px;">
                                <div class="editor-panel">
                                    <div style="font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#58a6ff;margin-bottom:14px;">
                                        Edytor pola #@(idx+1)
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                                        <div>
                                            <label class="fb-label">Etykieta *</label>
                                            <input @bind="f.Label" @bind:after="@(() => AutoKey(f))" class="fb-input" placeholder="Np. Imię i nazwisko" />
                                        </div>
                                        <div>
                                            <label class="fb-label">Klucz pola *</label>
                                            <input @bind="f.FieldKey" class="fb-input" placeholder="np. full_name" style="font-family:monospace;font-size:12px;" />
                                        </div>
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                                        <div>
                                            <label class="fb-label">Typ pola</label>
                                            <select @bind="f.Type" class="fb-select">
                                                @foreach (DomainFieldType ft in Enum.GetValues<DomainFieldType>())
                                                {
                                                    <option value="@ft">@GetDomainFieldTypeLabel(ft)</option>
                                                }
                                            </select>
                                        </div>
                                        <div>
                                            <label class="fb-label">Placeholder</label>
                                            <input @bind="f.Placeholder" class="fb-input" placeholder="Tekst pomocniczy..." />
                                        </div>
                                    </div>
                                    <div style="margin-bottom:12px;">
                                        <label class="fb-label">Tekst pomocy</label>
                                        <input @bind="f.HelpText" class="fb-input" placeholder="Dodatkowe wyjaśnienie dla użytkownika..." />
                                    </div>
                                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:12px;">
                                        <input type="checkbox" @bind="f.IsRequired" style="width:14px;height:14px;accent-color:#58a6ff;cursor:pointer;" />
                                        <span style="font-size:13px;color:#e6edf3;">Pole wymagane</span>
                                    </label>

                                    @if (f.Type is DomainFieldType.Select or DomainFieldType.MultiSelect or DomainFieldType.Radio or DomainFieldType.Checkbox)
                                    {
                                        <div>
                                            <label class="fb-label">Opcje wyboru</label>
                                            <div style="margin-bottom:8px;display:flex;flex-wrap:wrap;gap:4px;min-height:28px;">
                                                @if (f.Options is not null)
                                                {
                                                    @for (int oi = 0; oi < f.Options.Count; oi++)
                                                    {
                                                        var optIdx = oi;
                                                        <span class="opt-tag">
                                                            @f.Options[optIdx]
                                                            <span @onclick="@(() => RemoveOption(f, optIdx))"
                                                                  style="cursor:pointer;color:#f85149;font-weight:700;font-size:14px;line-height:1;">×</span>
                                                        </span>
                                                    }
                                                }
                                            </div>
                                            <div style="display:flex;gap:8px;">
                                                <input @bind="_newOption" @onkeyup="@(e => { if(e.Key=="Enter") AddOption(f); })"
                                                       class="fb-input" placeholder="Wpisz opcję i naciśnij Enter lub +"
                                                       style="flex:1;" />
                                                <button @onclick="@(() => AddOption(f))"
                                                        style="padding:9px 14px;border-radius:7px;border:1px solid rgba(88,166,255,0.3);background:rgba(88,166,255,0.1);color:#58a6ff;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;">
                                                    + Dodaj
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>

    @if (_showPreview)
    {
        <MudOverlay Visible="true" DarkBackground="true" @onclick="@(() => _showPreview = false)" />
        <div style="position:fixed;top:5vh;left:50%;transform:translateX(-50%);z-index:1001;width:560px;max-height:90vh;overflow-y:auto;background:#161b22;border:1px solid rgba(240,246,252,0.1);border-radius:12px;padding:28px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
                <div style="font-size:16px;font-weight:700;color:#e6edf3;">@_title — podgląd</div>
                <button @onclick="@(() => _showPreview = false)"
                        style="background:transparent;border:none;color:#7d8590;font-size:20px;cursor:pointer;">✕</button>
            </div>
            @foreach (var f in _fields.OrderBy(x => x.Order))
            {
                <div style="margin-bottom:16px;">
                    <label class="fb-label">@f.Label@(f.IsRequired ? " *" : "")</label>
                    @if (!string.IsNullOrEmpty(f.HelpText))
                    {
                        <div style="font-size:11px;color:#484f58;margin-bottom:4px;">@f.HelpText</div>
                    }
                    @if (f.Type == DomainFieldType.TextArea)
                    {
                        <textarea class="fb-input" placeholder="@f.Placeholder" rows="3" disabled style="resize:none;"></textarea>
                    }
                    else if (f.Type is DomainFieldType.Select or DomainFieldType.MultiSelect)
                    {
                        <select class="fb-select" disabled>
                            <option>@(f.Placeholder ?? "Wybierz...")</option>
                            @foreach (var opt in f.Options ?? [])
                            {
                                <option>@opt</option>
                            }
                        </select>
                    }
                    else if (f.Type is DomainFieldType.Radio or DomainFieldType.Checkbox)
                    {
                        @foreach (var opt in f.Options ?? [])
                        {
                            <label style="display:flex;align-items:center;gap:8px;margin-bottom:5px;cursor:pointer;">
                                <input type="@(f.Type == DomainFieldType.Radio ? "radio" : "checkbox")" disabled
                                       style="width:14px;height:14px;accent-color:#58a6ff;" />
                                <span style="font-size:13px;color:#e6edf3;">@opt</span>
                            </label>
                        }
                    }
                    else if (f.Type == DomainFieldType.Section)
                    {
                        <div style="height:1px;background:rgba(240,246,252,0.1);margin:4px 0 12px;"></div>
                    }
                    else
                    {
                        <input class="fb-input" type="@GetHtmlInputType(f.Type)" placeholder="@f.Placeholder" disabled />
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public int? FormId { get; set; }
    private bool IsNew => FormId is null;

    private string _code = "", _title = "", _description = "", _category = "", _departments = "";
    private int _escalationDays = 3;
    private bool _isActive = true, _reqApproval = true;
    private List<FormField> _fields = [];
    private List<string> _availableRoles = [], _assignedRoles = [];
    private bool _loading = true, _saving, _showPreview;
    private int _editingIndex = -1;
    private string _newOption = "";
    private string _lastSaved = "–";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _availableRoles = await db.Roles.Select(r => r.Name!).OrderBy(r => r).ToListAsync();

        if (!IsNew)
        {
            var form = await db.FormDefinitions
                .Include(f => f.Fields)
                .FirstOrDefaultAsync(f => f.Id == FormId);
            if (form is not null)
            {
                _code = form.Code; _title = form.Title; _description = form.Description ?? "";
                _category = form.Category ?? ""; _isActive = form.IsActive;
                _reqApproval = form.RequiresApproval;
                _escalationDays = form.EscalationAfterDays ?? 3;
                _assignedRoles = [.. form.AssignedRoles];
                _departments = string.Join(", ", form.AssignedDepartments);
                _fields = form.Fields.OrderBy(f => f.Order).ToList();
            }
        }
        _loading = false;
    }

    private void AddField()
    {
        var newField = new FormField
        {
            FieldKey = $"field_{_fields.Count + 1}",
            Label    = $"Pole {_fields.Count + 1}",
            Type     = DomainFieldType.Text,
            Order    = _fields.Count
        };
        _fields.Add(newField);
        _editingIndex = _fields.Count - 1;
    }

    private void ToggleEdit(int idx) => _editingIndex = _editingIndex == idx ? -1 : idx;

    private void RemoveField(int idx)
    {
        _fields.RemoveAt(idx);
        if (_editingIndex >= _fields.Count) _editingIndex = -1;
        ReorderFields();
    }

    private void MoveUp(int idx)
    {
        if (idx <= 0) return;
        (_fields[idx], _fields[idx - 1]) = (_fields[idx - 1], _fields[idx]);
        if (_editingIndex == idx) _editingIndex = idx - 1;
        else if (_editingIndex == idx - 1) _editingIndex = idx;
        ReorderFields();
    }

    private void MoveDown(int idx)
    {
        if (idx >= _fields.Count - 1) return;
        (_fields[idx], _fields[idx + 1]) = (_fields[idx + 1], _fields[idx]);
        if (_editingIndex == idx) _editingIndex = idx + 1;
        else if (_editingIndex == idx + 1) _editingIndex = idx;
        ReorderFields();
    }

    private void ReorderFields()
    {
        for (int i = 0; i < _fields.Count; i++) _fields[i].Order = i;
    }

    private void AutoKey(FormField f)
    {
        if (string.IsNullOrEmpty(f.Label)) return;
        f.FieldKey = f.Label.ToLower()
            .Replace(" ", "_").Replace("ą","a").Replace("ę","e").Replace("ó","o")
            .Replace("ś","s").Replace("ł","l").Replace("ż","z").Replace("ź","z")
            .Replace("ć","c").Replace("ń","n")
            .Where(c => char.IsLetterOrDigit(c) || c == '_')
            .Aggregate("", (s, c) => s + c);
    }

    private void AddOption(FormField f)
    {
        if (string.IsNullOrWhiteSpace(_newOption)) return;
        f.Options ??= [];
        f.Options.Add(_newOption.Trim());
        _newOption = "";
    }

    private void RemoveOption(FormField f, int idx) => f.Options?.RemoveAt(idx);

    private void ToggleRole(string role, bool val)
    {
        if (val) _assignedRoles.Add(role);
        else _assignedRoles.Remove(role);
    }

    private void Preview() => _showPreview = true;

    private async Task SaveAll()
    {
        if (string.IsNullOrWhiteSpace(_code) || string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Kod i tytuł są wymagane", Severity.Warning);
            return;
        }
        _saving = true;
        ReorderFields();

        await using var db = await DbFactory.CreateDbContextAsync();

        if (IsNew)
        {
            var form = new FormDefinition
            {
                Code = _code, Title = _title, Description = _description,
                Category = _category, IsActive = _isActive, RequiresApproval = _reqApproval,
                EscalationAfterDays = _escalationDays,
                AssignedRoles = [.. _assignedRoles],
                AssignedDepartments = _departments.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries),
                CreatedAt = DateTime.UtcNow
            };
            db.FormDefinitions.Add(form);
            await db.SaveChangesAsync();

            foreach (var f in _fields) { f.FormDefinitionId = form.Id; f.Id = 0; }
            db.FormFields.AddRange(_fields);
            await db.SaveChangesAsync();
        }
        else
        {
            var form = await db.FormDefinitions.FindAsync(FormId);
            if (form is null) { _saving = false; return; }
            form.Code = _code; form.Title = _title; form.Description = _description;
            form.Category = _category; form.IsActive = _isActive; form.RequiresApproval = _reqApproval;
            form.EscalationAfterDays = _escalationDays;
            form.AssignedRoles = [.. _assignedRoles];
            form.AssignedDepartments = _departments.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            var existingFields = await db.FormFields.Where(f => f.FormDefinitionId == FormId).ToListAsync();
            db.FormFields.RemoveRange(existingFields);
            await db.SaveChangesAsync();

            foreach (var f in _fields) { f.FormDefinitionId = FormId!.Value; f.Id = 0; }
            db.FormFields.AddRange(_fields);
            await db.SaveChangesAsync();
        }

        _saving = false;
        _lastSaved = DateTime.Now.ToString("HH:mm:ss");
        Snackbar.Add("Formularz zapisany", Severity.Success);
        if (IsNew) Nav.NavigateTo("/admin/forms");
    }

    private static string GetFieldIcon(DomainFieldType t) => t switch
    {
        DomainFieldType.Text          => "📝",
        DomainFieldType.TextArea      => "📄",
        DomainFieldType.Number        => "🔢",
        DomainFieldType.Decimal       => "💯",
        DomainFieldType.Date          => "📅",
        DomainFieldType.DateTime      => "🕐",
        DomainFieldType.Time          => "⏰",
        DomainFieldType.Select        => "🔽",
        DomainFieldType.MultiSelect   => "☑️",
        DomainFieldType.Radio         => "🔘",
        DomainFieldType.Checkbox      => "✅",
        DomainFieldType.FileUpload    => "📎",
        DomainFieldType.Signature     => "✍️",
        DomainFieldType.Table         => "📊",
        DomainFieldType.Section       => "─",
