@page "/forms/{Id:guid}"
@using BlazorApp.Domain.Entities
@using BlazorApp.Domain.Enums
@using BlazorApp.Infrastructure.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using System.Text.Json
@using DomainFieldType = BlazorApp.Domain.Enums.FieldType
@using BlazorApp.Web.Components.Modules.Approvals
@attribute [Authorize(Policy = "CanViewForms")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Szczegóły zgłoszenia</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_submission is null)
{
    <div style="text-align:center;padding:48px;color:#484f58;">Zgłoszenie nie istnieje</div>
}
else
{
    <div style="max-width:760px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                           OnClick="@(() => Nav.NavigateTo("/forms"))" />
            <div style="flex:1;">
                <div style="font-size:18px;font-weight:700;color:#e6edf3;">@_submission.FormDefinition?.Title</div>
                <div style="font-size:12px;color:#7d8590;margin-top:2px;">
                    Złożono @_submission.SubmittedAt.ToString("dd.MM.yyyy HH:mm")
                    · Termin @_submission.DueDate.ToString("dd.MM.yyyy")
                </div>
            </div>
            <span class="sz-badge-pill badge-@_submission.Status.ToString().ToLower()">
                @GetStatusLabel(_submission.Status)
            </span>
        </div>

        <div class="dash-panel" style="padding:20px;margin-bottom:12px;">
            <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:14px;">Szczegóły</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                <div>
                    <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Formularz</div>
                    <div style="font-size:13px;color:#e6edf3;">@_submission.FormDefinition?.Title</div>
                </div>
                <div>
                    <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Złożył</div>
                    <div style="font-size:13px;color:#e6edf3;">@_submission.SubmittedByUserId</div>
                </div>
                <div>
                    <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Status</div>
                    <span class="sz-badge-pill badge-@_submission.Status.ToString().ToLower()">@GetStatusLabel(_submission.Status)</span>
                </div>
                <div>
                    <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Termin</div>
                    <div style="font-size:13px;color:@(_submission.IsLate ? "#f85149" : "#e6edf3");">
                        @_submission.DueDate.ToString("dd.MM.yyyy")
                        @if (_submission.IsLate) { <span> ⚠ spóźnione</span> }
                    </div>
                </div>
                @if (_submission.ReviewedByUserId is not null)
                {
                    <div>
                        <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Zatwierdził</div>
                        <div style="font-size:13px;color:#e6edf3;">@_submission.ReviewedByUserId</div>
                    </div>
                    <div>
                        <div style="font-size:10px;color:#484f58;margin-bottom:3px;">Data decyzji</div>
                        <div style="font-size:13px;color:#e6edf3;">@_submission.ReviewedAt?.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(_submission.RejectionReason))
            {
                <div style="margin-top:14px;padding:12px;background:rgba(248,81,73,0.08);border-radius:8px;border:1px solid rgba(248,81,73,0.2);">
                    <div style="font-size:10px;color:#f85149;font-weight:600;margin-bottom:4px;">POWÓD ODRZUCENIA</div>
                    <div style="font-size:13px;color:#e6edf3;">@_submission.RejectionReason</div>
                </div>
            }
        </div>

        @if (_submission.FieldValues.TryGetValue("notes", out var notes))
        {
            <div class="dash-panel" style="padding:20px;margin-bottom:12px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:10px;">Uwagi</div>
                <div style="font-size:13px;color:#e6edf3;line-height:1.6;">@notes.GetString()</div>
            </div>
        }

        @if (_submission.FormDefinition?.Fields.Count > 0)
        {
            <div class="dash-panel" style="padding:20px;margin-bottom:12px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:14px;">Pola formularza</div>
                @foreach (var field in _submission.FormDefinition.Fields.OrderBy(f => f.Order))
                {
                    if (field.Type == DomainFieldType.Section)
                    {
                        <div style="font-size:11px;font-weight:700;color:#7d8590;text-transform:uppercase;margin:18px 0 8px;">@field.Label</div>
                    }
                    else
                    {
                        var managerOnly = IsManagerField(field);
                        var canEditManager = _canApprove && managerOnly && (_submission.Status == SubmissionStatus.Submitted || _submission.Status == SubmissionStatus.InReview);
                        <div style="@FieldBoxStyle(managerOnly)">
                            <label style="display:block;font-size:11px;font-weight:600;color:@(managerOnly ? "#24292f" : "#7d8590");margin-bottom:5px;">
                                @field.Label
                                @if (field.IsRequired) { <span style="color:#f85149;">*</span> }
                            </label>
                            @if (!string.IsNullOrWhiteSpace(field.HelpText))
                            {
                                <div style="font-size:11px;color:@(managerOnly ? "#57606a" : "#484f58");margin-bottom:7px;">@field.HelpText</div>
                            }

                            @if (canEditManager)
                            {
                                @RenderManagerEditor(field)
                                @if (_invalidManagerFields.Contains(field.FieldKey))
                                {
                                    <div style="font-size:11px;color:#f85149;margin-top:4px;">To pole jest wymagane przed zatwierdzeniem</div>
                                }
                            }
                            else
                            {
                                <div style="min-height:34px;padding:9px 10px;border-radius:7px;border:1px solid @(managerOnly ? "rgba(87,96,106,0.25)" : "rgba(240,246,252,0.1)");background:@(managerOnly ? "rgba(255,255,255,0.55)" : "rgba(240,246,252,0.04)");color:@(managerOnly ? "#24292f" : "#e6edf3");font-size:13px;white-space:pre-wrap;">
                                    @GetDisplayValue(field)
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }

        @if (_submission.Comments.Count > 0)
        {
            <div class="dash-panel" style="padding:20px;margin-bottom:12px;">
                <div style="font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#484f58;margin-bottom:14px;">Komentarze</div>
                @foreach (var c in _submission.Comments.OrderBy(x => x.CreatedAt))
                {
                    <div style="padding:10px 0;border-bottom:1px solid rgba(240,246,252,0.06);">
                        <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                            <span style="font-size:12px;color:#58a6ff;font-weight:500;">@c.UserId</span>
                            <span style="font-size:11px;color:#484f58;">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div style="font-size:13px;color:#e6edf3;">@c.Content</div>
                    </div>
                }
            </div>
        }

        @if (_submission.Status == SubmissionStatus.Draft && _isOwner)
        {
            <div style="display:flex;gap:12px;margin-top:8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitForReview">
                    Złóż do zatwierdzenia
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Delete">Usuń szkic</MudButton>
            </div>
        }
        else if (_canApprove && (_submission.Status == SubmissionStatus.Submitted || _submission.Status == SubmissionStatus.InReview))
        {
            <div style="display:flex;gap:12px;margin-top:8px;flex-wrap:wrap;">
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ApproveWithManagerFields">
                    Zapisz szare pola i zatwierdz
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RejectFromDetails">
                    Odrzuc formularz
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => Nav.NavigateTo("/approvals"))">
                    Wroc
                </MudButton>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private FormSubmission? _submission;
    private bool _loading = true, _isOwner, _canApprove;
    private string? _userId;
    private Dictionary<string, string> _managerValues = new();
    private Dictionary<string, List<string>> _managerMultiValues = new();
    private HashSet<string> _invalidManagerFields = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await using var db = await DbFactory.CreateDbContextAsync();
        _submission = await db.FormSubmissions
            .Include(s => s.FormDefinition).ThenInclude(f => f!.Fields)
            .Include(s => s.Comments)
            .FirstOrDefaultAsync(s => s.Id == Id);

        _isOwner = _submission?.SubmittedByUserId == _userId;
        _canApprove = HasRole(auth.User, "SuperAdmin") || HasRole(auth.User, "Admin") || HasRole(auth.User, "Manager")
            || auth.User.HasClaim("Module.Forms.Approve", "true");
        LoadManagerValues();
        _loading = false;
    }

    private async Task SubmitForReview()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var s = await db.FormSubmissions.FindAsync(Id);
        if (s is null) return;
        s.Status = SubmissionStatus.Submitted;
        await db.SaveChangesAsync();
        Snackbar.Add("Zgłoszenie złożone do zatwierdzenia", Severity.Success);
        Nav.NavigateTo("/forms");
    }

    private async Task Delete()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var s = await db.FormSubmissions.FindAsync(Id);
        if (s is null) return;
        db.FormSubmissions.Remove(s);
        await db.SaveChangesAsync();
        Snackbar.Add("Szkic usunięty", Severity.Info);
        Nav.NavigateTo("/forms");
    }

    private async Task ApproveWithManagerFields()
    {
        if (_submission?.FormDefinition is null) return;

        _invalidManagerFields.Clear();
        foreach (var field in _submission.FormDefinition.Fields.Where(f => IsManagerField(f) && f.IsRequired && f.Type != DomainFieldType.Section))
        {
            var hasValue = field.Type is DomainFieldType.Checkbox or DomainFieldType.MultiSelect
                ? _managerMultiValues.TryGetValue(field.FieldKey, out var selected) && selected.Count > 0
                : _managerValues.TryGetValue(field.FieldKey, out var value) && !string.IsNullOrWhiteSpace(value);
            if (!hasValue) _invalidManagerFields.Add(field.FieldKey);
        }

        if (_invalidManagerFields.Count > 0)
        {
            Snackbar.Add("Uzupelnij wymagane szare pola kierownika", Severity.Warning);
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.FormSubmissions.FindAsync(Id);
        if (item is null) return;

        foreach (var (key, value) in _managerValues)
            item.FieldValues[key] = JsonSerializer.SerializeToElement(value);

        foreach (var (key, values) in _managerMultiValues)
            item.FieldValues[key] = JsonSerializer.SerializeToElement(values);

        item.Status = SubmissionStatus.Approved;
        item.ReviewedByUserId = _userId;
        item.ReviewedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();

        Snackbar.Add("Formularz zatwierdzony", Severity.Success);
        Nav.NavigateTo("/approvals");
    }

    private async Task RejectFromDetails()
    {
        var parameters = new DialogParameters<RejectDialog> { { x => x.SubmissionId, Id } };
        var dialog = await DialogService.ShowAsync<RejectDialog>("Odrzuc formularz", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Formularz odrzucony", Severity.Info);
            Nav.NavigateTo("/approvals");
        }
    }

    private RenderFragment RenderManagerEditor(FormField field) => builder =>
    {
        if (field.Type == DomainFieldType.TextArea)
        {
            builder.OpenElement(0, "textarea");
            builder.AddAttribute(1, "rows", "3");
            builder.AddAttribute(2, "style", ManagerInputStyle);
            builder.AddAttribute(3, "value", GetManagerValue(field.FieldKey));
            builder.AddAttribute(4, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, e => SetManagerValue(field.FieldKey, e.Value?.ToString() ?? string.Empty)));
            builder.CloseElement();
            return;
        }

        if (field.Type == DomainFieldType.Radio || field.Type == DomainFieldType.Select)
        {
            foreach (var option in field.Options ?? [])
            {
                builder.OpenElement(10, "label");
                builder.AddAttribute(11, "style", "display:flex;align-items:center;gap:8px;margin:6px 0;color:#24292f;font-size:13px;");
                builder.OpenElement(12, "input");
                builder.AddAttribute(13, "type", "radio");
                builder.AddAttribute(14, "name", field.FieldKey);
                builder.AddAttribute(15, "checked", GetManagerValue(field.FieldKey) == option);
                builder.AddAttribute(16, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, _ => SetManagerValue(field.FieldKey, option)));
                builder.CloseElement();
                builder.AddContent(17, option);
                builder.CloseElement();
            }
            return;
        }

        if (field.Type == DomainFieldType.Checkbox || field.Type == DomainFieldType.MultiSelect)
        {
            foreach (var option in field.Options ?? [])
            {
                builder.OpenElement(20, "label");
                builder.AddAttribute(21, "style", "display:flex;align-items:center;gap:8px;margin:6px 0;color:#24292f;font-size:13px;");
                builder.OpenElement(22, "input");
                builder.AddAttribute(23, "type", "checkbox");
                builder.AddAttribute(24, "checked", IsManagerMultiSelected(field.FieldKey, option));
                builder.AddAttribute(25, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => ToggleManagerMulti(field.FieldKey, option, (bool)(e.Value ?? false))));
                builder.CloseElement();
                builder.AddContent(26, option);
                builder.CloseElement();
            }
            return;
        }

        builder.OpenElement(30, "input");
        builder.AddAttribute(31, "type", field.Type == DomainFieldType.Date ? "date" : "text");
        builder.AddAttribute(32, "style", ManagerInputStyle);
        builder.AddAttribute(33, "value", GetManagerValue(field.FieldKey));
        builder.AddAttribute(34, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, e => SetManagerValue(field.FieldKey, e.Value?.ToString() ?? string.Empty)));
        builder.CloseElement();
    };

    private void LoadManagerValues()
    {
        if (_submission?.FormDefinition is null) return;

        foreach (var field in _submission.FormDefinition.Fields.Where(IsManagerField))
        {
            if (!_submission.FieldValues.TryGetValue(field.FieldKey, out var value)) continue;
            if (value.ValueKind == JsonValueKind.Array)
                _managerMultiValues[field.FieldKey] = value.EnumerateArray().Select(x => x.GetString() ?? string.Empty).Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
            else
                _managerValues[field.FieldKey] = value.ToString();
        }
    }

    private string GetDisplayValue(FormField field)
    {
        if (_submission is null || !_submission.FieldValues.TryGetValue(field.FieldKey, out var value)) return "—";
        if (value.ValueKind == JsonValueKind.Array) return string.Join(", ", value.EnumerateArray().Select(x => x.GetString()));
        return value.ToString();
    }

    private string GetManagerValue(string key) => _managerValues.TryGetValue(key, out var value) ? value : string.Empty;
    private void SetManagerValue(string key, string value) { _managerValues[key] = value; _invalidManagerFields.Remove(key); }
    private bool IsManagerMultiSelected(string key, string option) => _managerMultiValues.TryGetValue(key, out var values) && values.Contains(option);
    private void ToggleManagerMulti(string key, string option, bool add)
    {
        if (!_managerMultiValues.ContainsKey(key)) _managerMultiValues[key] = [];
        if (add && !_managerMultiValues[key].Contains(option)) _managerMultiValues[key].Add(option);
        if (!add) _managerMultiValues[key].Remove(option);
        _invalidManagerFields.Remove(key);
    }

    private static bool IsManagerField(FormField field) =>
        field.ValidationRules is not null
        && field.ValidationRules.TryGetValue("fillRole", out var role)
        && role.ValueKind == JsonValueKind.String
        && role.GetString() == "manager";

    private static string FieldBoxStyle(bool managerOnly) => managerOnly
        ? "padding:12px;margin-bottom:12px;border-radius:8px;background:rgba(139,148,158,0.82);border:1px solid rgba(240,246,252,0.18);"
        : "padding:0;margin-bottom:12px;";

    private const string ManagerInputStyle = "width:100%;padding:9px 10px;border-radius:7px;border:1px solid rgba(87,96,106,0.35);background:rgba(255,255,255,0.8);color:#24292f;font-size:13px;box-sizing:border-box;";

    private static bool HasRole(System.Security.Claims.ClaimsPrincipal user, string role) =>
        user.IsInRole(role)
        || user.HasClaim(System.Security.Claims.ClaimTypes.Role, role)
        || user.HasClaim("role", role);

    private static string GetStatusLabel(SubmissionStatus s) => s switch
    {
        SubmissionStatus.Draft           => "Szkic",
        SubmissionStatus.Submitted       => "Złożony",
        SubmissionStatus.InReview        => "W przeglądzie",
        SubmissionStatus.Approved        => "Zatwierdzone",
        SubmissionStatus.Rejected        => "Odrzucony",
        SubmissionStatus.RequiresChanges => "Do poprawki",
        _ => s.ToString()
    };
}
